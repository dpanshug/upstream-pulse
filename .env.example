# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/upstream_pulse
REDIS_URL=redis://localhost:6379

# GitHub API
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_ORG=kubernetes

# GitHub org team sync (requires read:org scope to see private members)
GITHUB_TEAM_TOKEN=ghp_your_personal_pat_here
GITHUB_TEAM_ORG=your-github-org

# Insight Generation (optional - Google Gemini)
GOOGLE_AI_API_KEY=AIzaSy_your_google_ai_api_key_here

# Organization
ORG_NAME=My Organization
ORG_DESCRIPTION=Tracking upstream contributions across your portfolio
ORG_DOCS_URL=
TEAM_EMAIL_DOMAIN=example.com

# Application
NODE_ENV=development
PORT=4321
LOG_LEVEL=info

# Frontend
VITE_API_URL=http://localhost:4321

# Authorization — comma-separated admin users/groups
# In dev mode (no gateway headers), all users are admin by default
ADMIN_USERS=
ADMIN_GROUPS=

# Monitoring
PROMETHEUS_ENABLED=true
