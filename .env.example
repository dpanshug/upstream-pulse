# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/upstream_pulse
REDIS_URL=redis://localhost:6379

# GitHub API
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_ORG=kubernetes

# GitHub org team sync (requires read:org scope to see private members)
GITHUB_TEAM_TOKEN=ghp_your_personal_pat_here
GITHUB_TEAM_ORG=opendatahub-io

# AI Services
GOOGLE_AI_API_KEY=AIzaSy_your_google_ai_api_key_here

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Frontend
VITE_API_URL=http://localhost:3000

# Authentication (JWT)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Monitoring
PROMETHEUS_ENABLED=true
