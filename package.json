{
  "name": "upstream-pulse",
  "version": "1.0.0",
  "description": "AI-powered upstream open source contribution insights for your organization",
  "type": "module",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:studio": "cd backend && npm run db:studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy": "./deploy/deploy.sh deploy",
    "deploy:build": "./deploy/deploy.sh build",
    "deploy:push": "./deploy/deploy.sh push",
    "deploy:apply": "./deploy/deploy.sh apply",
    "deploy:status": "./deploy/deploy.sh status",
    "db:pgadmin": "docker start pgadmin || docker run -d --name pgadmin -p 5050:80 -e PGADMIN_DEFAULT_EMAIL=admin@admin.com -e PGADMIN_DEFAULT_PASSWORD=admin dpage/pgadmin4",
    "db:port-forward": "oc -n upstream-pulse port-forward svc/postgres 5433:5432"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpanshug/upstream-pulse.git"
  },
  "keywords": [
    "open-source",
    "contribution-tracking",
    "analytics",
    "ai-insights",
    "github",
    "upstream"
  ],
  "author": "Upstream Pulse Contributors",
  "license": "Apache-2.0"
}
