{
  "name": "upstream-pulse-backend",
  "version": "1.0.0",
  "description": "Backend service for Upstream Pulse - open source contribution tracking",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "worker": "tsx watch src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/shared/database/run-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/scripts/seed-sample-data.ts",
    "db:backfill-github-ids": "tsx src/scripts/backfill-github-ids.ts",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@fastify/cors": "^8.4.2",
    "@fastify/websocket": "^8.3.1",
    "@google/generative-ai": "^0.1.3",
    "@octokit/plugin-throttling": "^9.6.1",
    "@octokit/rest": "^20.0.2",
    "bullmq": "^4.15.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.1",
    "fastify": "^4.25.1",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.1",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.20.7",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
